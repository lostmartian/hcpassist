# pyenv
#   For a library or binary, you wish to ignore these files if they manage
#   the Python version locally.
# .python-version

# pipenv
#   According to pypa/pipenv#1191, it is recommended to not ignore Pipfile.lock.
#   If you are part of a development team or using a CI tool you may want to share this file.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# .pdm-python
# .pdm-build/

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

